# Runtime roots
VAULT_ROOT=/home/ubuntu/obsidian-vault
RUNTIME_ROOT=/srv/synapsenote
FLASK_SECRET_KEY=generate_this_random_hex_string

# SynapseNote API
SYNAPSENOTE_USER_ID=solo
SYNAPSENOTE_USER_PASSWORD=change_this_app_password
SYNAPSENOTE_SESSION_SECRET=change_this_session_secret

COUCHDB_USER=obsidian_admin
COUCHDB_PASSWORD=change_this_couchdb_password
COUCHDB_URL=http://couchdb:5984
SYNAPSENOTE_CHAT_STORE=couchdb
SYNAPSENOTE_CHAT_DB=synapsenote_chat

GENERIC_TIMEZONE=Asia/Seoul

# SynapseNote Frontend
BACKEND_ORIGIN=http://synapsenote-api:8000

# LiveSync crypto (do not change without migration plan)
LIVESYNC_PASSPHRASE=change_this_livesync_passphrase
LIVESYNC_OBFUSCATE_PASSPHRASE=change_this_livesync_obfuscate_passphrase

# Backup Settings
BACKUP_RETENTION_BYTES=1073741824
BACKUP_LOCAL_CRON="0 */6 * * *"
BACKUP_GDRIVE_CRON="0 3 * * *"
BACKUP_KEEP_DAYS_TRASH=30
BACKUP_KEEP_VERSIONS=20
RCLONE_REMOTE_NAME=gdrive
RCLONE_REMOTE_PATH=obsidian-vault-backups/obsidian-vault
